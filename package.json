{
  "name": "mn-sushi-pos",
  "version": "1.2.0",
  "private": true,
  "description": "MN Sushi POS desktop wrapper",
  "main": "electron/main.js",
  "scripts": {
    "postinstall": "electron-builder install-app-deps",
    "desktop:rebuild-native": "electron-rebuild -f -w better-sqlite3",
    "desktop:dev": "electron .",
    "desktop:dev:fresh": "npm run desktop:rebuild-native && electron .",
    "desktop:pack": "npm run desktop:rebuild-native && electron-builder --dir",
    "desktop:dist": "npm run desktop:rebuild-native && electron-builder --win nsis portable",
    "obfuscate:index": "node scripts/obfuscate-index.js"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "electron": "^31.7.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "az.mnsushi.pos",
    "productName": "MN Sushi POS",
    "icon": "build/icon.png",
    "asar": true,
    "files": [
      "index.html",
      "build/**/*",
      "*.png",
      "*.jpg",
      "*.jpeg",
      "*.webp",
      "*.gif",
      "*.svg",
      "css2",
      "electron/**/*"
    ],
    "directories": {
      "output": "dist"
    },
    "win": {
      "icon": "build/icon.png",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dependencies": {
    "better-sqlite3": "^12.8.0",
    "express": "^5.2.1",
    "javascript-obfuscator": "^5.4.1",
    "node-machine-id": "^1.1.12"
  }
}
