<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#0f131a">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/config_title"
            android:textColor="#ffffff"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="@string/config_hint"
            android:textColor="#a7b2c1"
            android:textSize="14sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/server_url_label"
            android:textColor="#ffffff"
            android:textSize="14sp" />

        <EditText
            android:id="@+id/serverUrlInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@android:drawable/edit_text"
            android:hint="@string/server_url_hint"
            android:importantForAutofill="no"
            android:inputType="textUri"
            android:maxLines="1"
            android:padding="12dp"
            android:textColor="#ffffff"
            android:textColorHint="#6e7f97" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="@string/pin_label"
            android:textColor="#ffffff"
            android:textSize="14sp" />

        <EditText
            android:id="@+id/adminPinInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@android:drawable/edit_text"
            android:hint="@string/pin_hint"
            android:importantForAutofill="no"
            android:inputType="numberPassword"
            android:maxLength="8"
            android:padding="12dp"
            android:textColor="#ffffff"
            android:textColorHint="#6e7f97" />

        <Button
            android:id="@+id/saveAndOpenBtn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/save_and_open" />

    </LinearLayout>

</ScrollView>

